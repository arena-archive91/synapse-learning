{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "npm run typecheck && npm run typecheck --prefix server",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "build": "npm run typecheck:all && vite build",
    "build:fast": "vite build",
    "preview": "vite preview",
    "postinstall": "node scripts/copy-pyodide.mjs"
  },
  "dependencies": {
    "@codemirror/lang-python": "^6.2.1",
    "@uiw/react-codemirror": "^4.25.10",
    "clsx": "2.1.1",
    "framer-motion": "^12.40.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.47",
    "lucide-react": "^1.21.0",
    "mammoth": "^1.9.0",
    "mermaid": "^11.15.0",
    "pdfjs-dist": "^4.10.38",
    "pyodide": "^0.26.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "3.4.0",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/vite": "4.1.17",
    "@types/katex": "^0.16.8",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vitest": "^3.2.4"
  }
}
